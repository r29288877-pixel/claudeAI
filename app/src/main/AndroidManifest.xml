<manifest xmlns:android="android.com" package="com.my.autoclicker">
    
    <!-- 懸浮窗權限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application android:theme="@style/Theme.Material3.DayNight">
        
        <!-- 主界面 -->
        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 核心：模擬點擊的無障礙服務 -->
        <service android:name=".MacroAccessibilityService"
                 android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
                 android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data android:name="android.accessibilityservice" android:resource="@xml/accessibility_config" />
        </service>
    </application>
</manifest>
